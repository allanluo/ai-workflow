{
  "name": "ai-workflow",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "dev": "pnpm --parallel --filter @ai-workflow/backend --filter @ai-workflow/frontend dev",
    "dev:frontend": "pnpm --filter @ai-workflow/frontend dev",
    "dev:backend": "pnpm --filter @ai-workflow/backend dev",
    "dev:electron": "pnpm --filter @ai-workflow/frontend dev:electron",
    "build": "pnpm -r build",
    "check": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "db:generate": "pnpm --filter @ai-workflow/database db:generate",
    "db:migrate": "pnpm --filter @ai-workflow/database db:migrate",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "electron",
      "esbuild"
    ]
  },
  "devDependencies": {
    "prettier": "^3.8.2"
  }
}
